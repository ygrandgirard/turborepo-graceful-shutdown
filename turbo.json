{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "//#start": {
      "cache": false,
      "env": ["NPM_CONFIG_SCRIPT_SHELL"]
    },
    "build": {
      "dependsOn": [
        "prebuild",
        "^build"
      ],
      "outputs": [
        "output-file.txt",
        "dist/**"
      ]
    },
    "prebuild": {},
    "lint": {},
    "check-types": {}
  }
}
